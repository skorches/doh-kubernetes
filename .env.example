# DNS over HTTPS (DoH) Smart DNS — Kubernetes Configuration
#
# IMPORTANT: This file is flexible and editable!
# Change any value below, then run: bash scripts/deploy.sh
# You don't need to re-run install.sh to change configuration.
#
# =========================================================================
# REQUIRED SETTINGS
# =========================================================================

# Your VPS/Node public IP address (REQUIRED)
# This is the IP that clients will connect to
# Example: 151.241.227.116
VPS_IP=

# Your domain name for HTTPS/DoH endpoint (REQUIRED)
# This domain MUST have a valid certificate:
# - Let's Encrypt cert at /etc/letsencrypt/live/your-domain/
# - Or setup will generate a self-signed certificate
#
# Change this anytime by editing and running: bash scripts/deploy.sh
#
# Examples:
#   DOMAIN=doh.example.com
#   DOMAIN=440.info
#   DOMAIN=bypass.mysite.com
DOMAIN=

# =========================================================================
# ADVANCED SETTINGS (Usually don't need to change)
# =========================================================================

# Kubernetes namespace where DoH stack runs
NAMESPACE=doh-system

# Deployment overlay (base or production)
# - base: 2 replicas, minimal resources (testing/small servers)
# - production: 3 replicas, more resources (production use)
OVERLAY=base


